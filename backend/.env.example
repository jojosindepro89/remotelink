# ── Server ─────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── Database ────────────────────────────────────────────────────
# Railway will provide this automatically when you add MongoDB service
MONGODB_URI=mongodb://localhost:27017/remotelink

# ── Auth ────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret-in-production
JWT_EXPIRES_IN=30d

# ── WebRTC TURN/STUN ────────────────────────────────────────────
# Free STUN only (no TURN key needed for LAN/same-network):
# Add Twilio/Xirsys keys here for cross-NAT production:
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# XIRSYS_URL=https://global.xirsys.net/_turn/remotelink

# ── CORS ────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://remotelink.vercel.app,http://localhost:5173

# ── Session ─────────────────────────────────────────────────────
SESSION_SECRET=change-me-too
SESSION_CODE_TTL=86400

# ── Uploads ─────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=500
UPLOAD_DIR=./uploads
