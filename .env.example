# ── RemoteLink Root Environment ──────────────────────────────
# Copy to .env and fill in your values

# MongoDB
MONGO_ROOT_PASSWORD=your_secure_mongo_password

# JWT Secrets (generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))")
JWT_SECRET=your_jwt_secret_min_32_chars
REFRESH_TOKEN_SECRET=your_refresh_secret_min_32_chars

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# TURN Server (optional - for NAT traversal)
TURN_URL=turn:your-server.com:3478
TURN_USERNAME=turnuser
TURN_CREDENTIAL=turnpassword
